 SKIN = LIRE 'STL' 'skin.stl'; 
 RIB0 = LIRE 'STL' 'rib0.stl'; 
 RIB750 = LIRE 'STL' 'rib750.stl'; 
 RIB1500 = LIRE 'STL' 'rib1500.stl'; 
 RIB2250 = LIRE 'STL' 'rib2250.stl'; 
 RIB3000 = LIRE 'STL' 'rib3000.stl'; 
 SPAR_MAIN = LIRE 'STL' 'spar_main.stl'; 
 SPAR_TAIL = LIRE 'STL' 'spar_tail.stl'; 
   
 RIBS = RIB0 ET RIB750 ET RIB1500 ET RIB2250 ET RIB3000; 
 SPARS = SPAR_MAIN ET SPAR_TAIL; 
 ELIM 1.E-6 RIBS; 
 ELIM 1.E-6 SPARS; 
 ELIM 1.E-6 SKIN; 
   
 MESH = SKIN ET RIBS ET SPARS; 
 ELIM 1.E-6 MESH; 
   
 OPTI 'DIME' 3 'ELEM' 'TRI3'; 
   
 THICKNESS = 1E-3; 
 YOUNG     = 210.E9; 
 NU        = 0.3; 
   
 SMOD = MODE SKIN 'MECANIQUE' 'ELASTIQUE' 'DKT'; 
 SMAT = MATE SMOD 'YOUN' YOUNG 'NU' NU 'EPAI' THICKNESS; 
 SPMOD = MODE SPARS 'MECANIQUE' 'ELASTIQUE' 'DKT'; 
 SPMAT = MATE SPMOD 'YOUN' YOUNG 'NU' NU 'EPAI' THICKNESS; 
 RMOD = MODE RIBS 'MECANIQUE' 'ELASTIQUE' 'DKT'; 
 RMAT = MATE RMOD 'YOUN' YOUNG 'NU' NU 'EPAI' THICKNESS; 
 WMOD = SMOD ET RMOD ET SPMOD; 
 WMAT = SMAT ET RMAT ET SPMAT; 
   
 ROOT_POINT = MESH POIN 'PLAN' (-1000. 0. 0.) (0. 0. 1000.) (0. 0. 0.) 1.E-3; 
 ORIGIN     = MESH POIN 'PROC' (0.0 0. 0.); 
   
 ROOT1 = BLOQ 'DEPL' 'ROTA' ROOT_POINT; 
 ROOT2 = BLOQ 'ROTA' ORIGIN; 
 ROOT_BLOQ = ROOT1 ET ROOT2; 
   
   
   
 TAB_TRACTION = LIRE 'CSV' 'CASTEMForce.csv' 'DEBU' 2 'SEPA' ';' 'COLO'; 
 TX_LIST = TAB_TRACTION . 4; 
 TY_LIST = TAB_TRACTION . 5; 
 TZ_LIST = TAB_TRACTION . 6; 
   
 MESS 'IMPORTED TRACTIONS: ' (DIME TX_LIST) ' VALUES'; 
   
 SKIN_POI = CHAN 'POI1' SKIN; 
   
 TAB_FORCE = LIRE 'CSV' 'CASTEMForce.csv' 'DEBU' 2 'SEPA' ';' 'COLO'; 
 FX_LIST = TAB_FORCE . 4; 
 FY_LIST = TAB_FORCE . 5; 
 FZ_LIST = TAB_FORCE . 6; 
   
 FX_FIELD = MANU 'CHPO' SKIN_POI 1 'FX' FX_LIST 'NATURE' 'DISCRET'; 
 FY_FIELD = MANU 'CHPO' SKIN_POI 1 'FY' FY_LIST 'NATURE' 'DISCRET'; 
 FZ_FIELD = MANU 'CHPO' SKIN_POI 1 'FZ' FZ_LIST 'NATURE' 'DISCRET'; 
 FORCE_TOTAL = FX_FIELD ET FY_FIELD ET FZ_FIELD; 
 MESS 'FORCE TOTAL CREATED'; 
   
   
   
 RIGIDITE = RIGI WMOD WMAT; 
 KK       = RIGIDITE ET ROOT_BLOQ; 
 UU       = RESO KK FORCE_TOTAL; 
   
 UZMAX = MAXI (EXCO UU UZ) ABS; 
 UXMAX = MAXI (EXCO UU UX) ABS; 
 UYMAX = MAXI (EXCO UU UY) ABS; 
 RZMAX = MAXI (EXCO UU RZ) ABS; 
 RXMAX = MAXI (EXCO UU RX) ABS; 
 RYMAX = MAXI (EXCO UU RY) ABS; 
   
 MESS 'MAX UX: ' UXMAX ' m'; 
 MESS 'MAX UY: ' UYMAX ' m'; 
 MESS 'MAX UZ: ' UZMAX ' m'; 
   
 MESS 'MAX RX: ' RXMAX ' rad'; 
 MESS 'MAX RY: ' RYMAX ' rad'; 
 MESS 'MAX RZ: ' RZMAX ' rad'; 
